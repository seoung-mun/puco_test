# ────────────────────────────────────────────────
# Puerto Rico AI Battle Platform — Environment Variables
# Copy this file to .env and fill in the values.
# Optional helper: python3 backend/scripts/bootstrap_env_secrets.py --env-file .env
# ────────────────────────────────────────────────

# ── Database (PostgreSQL) ──────────────────────
POSTGRES_USER=puco_user
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/puco_rl

# ── Redis ──────────────────────────────────────
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Frontend → Backend proxy ───────────────────
# In Docker: http://backend:8000
# In local dev: http://localhost:8000
VITE_API_TARGET=http://backend:8000

# ── Security ───────────────────────────────────
# REQUIRED in production. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-64-char-hex-string

# REQUIRED for Legacy API write endpoints (X-API-Key header).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=change-me-generate-a-random-64-char-hex-string
VITE_INTERNAL_API_KEY=change-me-same-value-as-INTERNAL_API_KEY

# ── CORS ───────────────────────────────────────
# Comma-separated list of allowed origins.
# Leave unset for local dev (defaults to localhost:3000 and localhost:5173).
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Debug mode ─────────────────────────────────
# Set to "true" ONLY in local development.
# Enables /api/v1/auth/mock-login endpoint.
DEBUG=false

# ── Bot model ──────────────────────────────────
# MODEL_TYPE selects the agent architecture:
#   ppo  → Agent (standard PPO, uses PPO_MODEL_FILENAME)
#   hppo → PhasePPOAgent / HierarchicalAgent (uses HPPO_MODEL_FILENAME)
# Must match the architecture used during training.
MODEL_TYPE=ppo

# Filename inside PuCo_RL/models/
# If you use the checkpoints committed in this repository, keep these defaults.
PPO_MODEL_FILENAME=PPO_PR_Server_순수자기대결_20260406_135525_step_99942400.pth
HPPO_MODEL_FILENAME=HPPO_PR_Server_1774241514_step_14745600.pth

# ── Google OAuth ───────────────────────────────
# REQUIRED for Google Sign-In.
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Add the exact frontend origin as an Authorized JavaScript origin.
# Examples:
#   http://localhost:3000      (dev compose / Vite dev server)
#   http://localhost           (prod compose on port 80)
#   http://localhost:3000      (prod compose if FRONTEND_PORT=3000)
#
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional: published port for docker-compose.prod.yml frontend.
# FRONTEND_PORT=80
